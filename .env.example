# Nexus configuration. Copy this file to .env and fill in the required values.
#
#   cp .env.example .env
#
# Everything except the two secrets at the top has a working default.

# --- Required ----------------------------------------------------------------

# AES-256-GCM key for encrypting sensitive connector fields (IMAP passwords,
# Telegram credentials, API keys) before they hit Postgres. Must be 64 hex chars
# (32 bytes). Generate one with:
#
#   openssl rand -hex 32
#
# ⚠  If you lose this key, all encrypted connector configs become unreadable and
#    you will need to re-enter credentials for every connector.
NEXUS_ENCRYPTION_KEY=

# JWT signing secret for session tokens. If left empty, Nexus generates a random
# one at boot — which logs everyone out on every restart. Set it once and forget.
# Any long random string works; 32+ bytes recommended:
#
#   openssl rand -base64 48
NEXUS_JWT_SECRET=

# --- Optional: where your data lives -----------------------------------------

# Host directory to expose to the filesystem connector as /data (read-only).
# Defaults to the bundled ./testdata so a fresh clone boots with demo content.
# Point this at your real data once you are done poking around.
# NEXUS_DATA_PATH=/srv/nexus/data

# Glob patterns the filesystem connector will index.
# NEXUS_FS_PATTERNS=*.txt,*.md,*.pdf,*.docx,*.xlsx,*.pptx,*.doc,*.xls,*.jpg,*.png

# --- Optional: ports ---------------------------------------------------------

# NEXUS_PORT=8080
# NEXUS_DB_PORT=5432
# NEXUS_OPENSEARCH_PORT=9200
# NEXUS_TIKA_PORT=9998
# NEXUS_OLLAMA_PORT=11434

# --- Optional: runtime tuning ------------------------------------------------

# OpenSearch JVM heap. Bump to 1g+ if you index a lot of data.
# OPENSEARCH_HEAP=512m

# Comma-separated CORS origins. Add your domain when serving behind a reverse
# proxy. The backend's default (http://localhost:5173) already covers the Vite
# dev server.
# NEXUS_CORS_ORIGINS=https://nexus.example.com

# NEXUS_LOG_LEVEL=info
