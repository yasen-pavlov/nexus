                    "application/json"
                ],
                "tags": [
                    "connectors"
                ],
                "summary": "Create a new connector",
                "parameters": [
                    {
                        "description": "Connector config",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_api.createConnectorRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
