        },
        "/sync/cursors/{connector}": {
            "delete": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sync"
                ],
                "summary": "Delete a single connector's sync cursor",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Connector name",
                        "name": "connector",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/internal_api.APIResponse"
                        }
                    }
                }
            }
        },
        "/sync/{connector}": {
            "post": {
                "description": "Starts an async sync job. Returns immediately with the job state.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sync"
                ],
                "summary": "Trigger sync for a single connector",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Connector name",
                        "name": "connector",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "$ref": "#/definitions/internal_api.SyncJob"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/internal_api.APIResponse"
                        }
                    },
                    "409": {
                        "description": "Sync already running",
                        "schema": {
                            "$ref": "#/definitions/internal_api.APIResponse"
                        }
                    }
                }
            }
        },
        "/sync/{connector}/progress": {
            "get": {
                "description": "Opens a Server-Sent Events stream that pushes SyncJob updates in real-time. Sends an \"event: done\" when the job completes.",
                "produces": [
                    "text/event-stream"
                ],
                "tags": [
                    "sync"
                ],
                "summary": "Stream sync progress via SSE",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Connector name",
                        "name": "connector",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "SSE stream",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/internal_api.APIResponse"
                        }
                    }
                }
            }
        }
    },
