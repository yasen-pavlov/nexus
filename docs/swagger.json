                            "$ref": "#/definitions/internal_api.APIResponse"
                        }
                    },
                    "409": {
                        "description": "Name already exists",
                        "schema": {
                            "$ref": "#/definitions/internal_api.APIResponse"
                        }
                    }
                }
            }
        },
        "/connectors/{id}": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "connectors"
                ],
                "summary": "Get a connector by ID",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Connector UUID",
                        "name": "id",
                        "in": "path",
