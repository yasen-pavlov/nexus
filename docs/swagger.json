                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/internal_api.APIResponse"
                        }
                    }
                }
            }
        },
        "/sync": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sync"
                ],
                "summary": "List active and recent sync jobs",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/internal_api.SyncJob"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Starts async sync jobs for all enabled connectors. Skips connectors that are already syncing.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sync"
                ],
                "summary": "Sync all enabled connectors",
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/internal_api.SyncJob"
                            }
                        }
                    }
                }
            }
        },
        "/sync/cursors": {
            "delete": {
                "description": "Clears all sync cursors, forcing a full re-sync on next trigger.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sync"
                ],
                "summary": "Delete all sync cursors",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
